# ISPS HBT System - Environment Variables
# Copy this to .env and fill in your values

PORT=5050
DB_PATH=./isps_hbt.db
UPLOAD_DIR=./uploads
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# LLM API Keys (can also be set via the Configuration page in the UI)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
